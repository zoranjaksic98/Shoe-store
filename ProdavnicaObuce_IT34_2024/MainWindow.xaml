<Window x:Class="ProdavnicaObuce_IT34_2024.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProdavnicaObuce_IT34_2024"
        mc:Ignorable="d"
        Title="Prodavnica obuce" Height="350" Width="650">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="Images\Obuca.png"
                        Stretch="UniformToFill"/>
        </Grid.Background>
        <DataGrid x:Name="dataGridCentralni" HorizontalAlignment="Center" VerticalAlignment="Center" Height="auto" Width="auto"
                  IsReadOnly="True" CanUserAddRows="False" AlternatingRowBackground="Gray" SelectionUnit="FullRow" SelectionMode="Single"/>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Height="30" Width="auto" Orientation="Horizontal">
            <Button x:Name="btnKategorije" Content="Kategorije" HorizontalAlignment="Left" Width="75" Height="30" VerticalAlignment="Top" Click="btnKategorije_Click"/>
            <Button x:Name="btnKolekcije" Content="Kolekcije" HorizontalAlignment="Left" Width="75" Height="30" VerticalAlignment="Top" Click="btnKolekcije_Click"/>
            <Button x:Name="btnKupci" Content="Kupci" HorizontalAlignment="Left" Width="75" Height="30" VerticalAlignment="Top" Click="btnKupci_Click"/>
            <Button x:Name="btnObuce" Content="Obuće" HorizontalAlignment="Left" Width="75" Height="30" VerticalAlignment="Top" Click="btnObuce_Click"/>
            <Button x:Name="btnPorudzbine" Content="Porudžbine" HorizontalAlignment="Left" Width="75" Height="30" VerticalAlignment="Top" Click="btnPorudzbine_Click"/>
            <Button x:Name="btnProizvodjaci" Content="Proizvođači" HorizontalAlignment="Left" Width="75" Height="30" VerticalAlignment="Top" Click="btnProizvodjaci_Click"/>
            <Button x:Name="btnRacuni" Content="Računi" HorizontalAlignment="Left" Width="75" Height="30" VerticalAlignment="Top" Click="btnRacuni_Click"/>
            <Button x:Name="btnVrste" Content="Vrste" HorizontalAlignment="Left" Width="75" Height="30" VerticalAlignment="Top" Click="btnVrste_Click"/>
        </StackPanel>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="30" Width="auto" Orientation="Horizontal">
            <Button x:Name="btnDodaj" Content="Dodaj" HorizontalAlignment="Left" Width="75" Height="30" VerticalAlignment="Top" Click="btnDodaj_Click"/>
            <Button x:Name="btnIzmeni" Content="Izmeni" HorizontalAlignment="Left" Width="75" Height="30" VerticalAlignment="Top" Click="btnIzmeni_Click"/>
            <Button x:Name="btnObrisi" Content="Obriši" HorizontalAlignment="Left" Width="75" Height="30" VerticalAlignment="Top" Click="btnObrisi_Click"/>
        </StackPanel>
    </Grid>
</Window>
