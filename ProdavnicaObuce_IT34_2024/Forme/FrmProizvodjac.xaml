<Window x:Class="ProdavnicaObuce_IT34_2024.Forme.FrmProizvodjac"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProdavnicaObuce_IT34_2024.Forme"
        mc:Ignorable="d"
        Title="Dodaj/Izmeni proizvodjaca" Height="290" Width="300">
    <Grid Background="AliceBlue">
        <Label Content="Ime proizvođača" HorizontalAlignment="Left" Margin="30,20,0,0" VerticalAlignment="Top"/>
        <Label Content="Zemlja porekla" HorizontalAlignment="Left" Margin="30,50,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TxtIme" HorizontalAlignment="Left" Margin="150,20,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Height="23" Width="120"/>
        <TextBox x:Name="TxtZemljaPorekla" HorizontalAlignment="Left" Margin="150,50,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Height="23" Width="120"/>
        <Button x:Name="BtnSacuvaj" Content="Sačuvaj" HorizontalAlignment="Left" Margin="30,190,0,0" Width="75" VerticalAlignment="Top" Click="BtnSacuvaj_Click"/>
        <Button x:Name="BtnOtkazi" Content="Otkaži" HorizontalAlignment="Right" Margin="30,190,30,0" Width="75" VerticalAlignment="Top" Click="BtnOtkazi_Click"/>
    </Grid>
</Window>
